<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IdulStudio - Video Creator & Editor Portfolio</title>
    
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Plus Jakarta Sans', 'Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        /* Custom smooth scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 9999px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="min-h-screen bg-slate-50 text-slate-800 antialiased overflow-x-hidden selection:bg-indigo-600 selection:text-white">

    <!-- Alert Toast (Notification) -->
    <div id="alert-toast" class="fixed top-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-xl backdrop-blur-md border border-emerald-200 bg-emerald-50 text-emerald-800 transition-all duration-300 transform translate-y-[-150%] opacity-0 pointer-events-none">
        <i id="alert-icon" class="fa-solid fa-circle-check text-emerald-500 text-lg"></i>
        <span id="alert-msg" class="text-sm font-semibold">Portofolio berhasil ditambahkan!</span>
    </div>

    <!-- Confirm Reset Modal -->
    <div id="confirm-reset-modal" class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm hidden items-center justify-center p-4">
        <div class="bg-white rounded-2xl max-w-md w-full p-6 shadow-2xl border border-slate-200 transform scale-95 transition-all duration-300">
            <div class="flex items-center gap-3 text-amber-600 mb-4">
                <i class="fa-solid fa-triangle-exclamation text-xl"></i>
                <h3 class="font-extrabold text-lg text-slate-900">Konfirmasi Reset Data</h3>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-6">
                Apakah Anda yakin ingin mengatur ulang data kembali ke contoh default? Seluruh data kustomisasi portofolio dan brand klien yang belum disimpan akan hilang secara permanen.
            </p>
            <div class="flex gap-3 justify-end">
                <button onclick="closeResetModal()" class="px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-xl transition">
                    Batal
                </button>
                <button onclick="handleResetToDefault()" class="bg-red-600 hover:bg-red-500 text-white font-bold px-4 py-2 rounded-xl text-sm transition">
                    Ya, Atur Ulang
                </button>
            </div>
        </div>
    </div>

    <!-- Navigation Header -->
    <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur-md border-b border-slate-200/60 px-6 py-4 transition-all">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="bg-gradient-to-tr from-indigo-600 to-violet-600 p-2.5 rounded-xl shadow-md shadow-indigo-500/10 flex items-center justify-center">
                    <i class="fa-solid fa-video text-white text-lg"></i>
                </div>
                <div>
                    <span class="font-black text-2xl tracking-tight bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-500 bg-clip-text text-transparent">
                        IdulStudio
                    </span>
                    <span class="hidden sm:inline-block text-[10px] text-slate-400 font-extrabold tracking-widest uppercase ml-3 border-l border-slate-200 pl-3">
                        VIDEO CREATOR & EDITOR
                    </span>
                </div>
            </div>

            <div class="flex items-center gap-6">
                <a href="#gallery-portfolio" class="hidden lg:inline-block text-sm text-slate-600 hover:text-indigo-600 transition font-semibold">Galeri Video</a>
                <a href="#brand-portfolio" class="hidden lg:inline-block text-sm text-slate-600 hover:text-indigo-600 transition font-semibold">Brand Klien</a>
                <a href="#tentang-saya" class="hidden lg:inline-block text-sm text-slate-600 hover:text-indigo-600 transition font-semibold">Tentang</a>
                <a href="#hubungi-saya" class="hidden lg:inline-block text-sm text-slate-600 hover:text-indigo-600 transition font-semibold">Kontak</a>

                <button 
                    onclick="toggleAdminMode()"
                    id="btn-admin-toggle"
                    class="flex items-center gap-2 text-xs font-bold px-4 py-2.5 rounded-xl border bg-white text-slate-700 border-slate-200 hover:border-indigo-500/50 hover:bg-slate-50 transition-all"
                >
                    <i class="fa-solid fa-gear"></i>
                    <span id="admin-toggle-text">Kelola Portofolio</span>
                </button>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative py-24 px-6 overflow-hidden bg-gradient-to-b from-white to-slate-100/50">
        <div class="absolute top-10 left-1/4 w-[350px] h-[350px] bg-indigo-100/40 rounded-full blur-[120px] pointer-events-none"></div>
        <div class="absolute bottom-10 right-1/4 w-[400px] h-[400px] bg-violet-100/30 rounded-full blur-[140px] pointer-events-none"></div>
        
        <div class="max-w-5xl mx-auto text-center relative z-10">
            <div class="inline-flex items-center gap-2 bg-indigo-50 border border-indigo-100/80 text-indigo-700 rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wider mb-6">
                <i class="fa-solid fa-wand-magic-sparkles text-indigo-600 animate-pulse"></i>
                Social Media Video Specialist
            </div>
            
            <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black leading-tight tracking-tight mb-6 text-slate-900">
                Hadirkan Konten Visual <br>
                <span class="bg-gradient-to-r from-indigo-600 via-violet-600 to-indigo-500 bg-clip-text text-transparent">
                    Berretensi Tinggi & Estetik
                </span>
            </h1>
            
            <p class="text-slate-600 text-base sm:text-xl max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
                Membantu brand, agensi, dan kreator meningkatkan jangkauan di <strong class="text-slate-900 font-semibold">Instagram, TikTok, dan YouTube</strong> melalui racikan pacing editing yang dinamis, teknik transisi mulus, dan perancangan audio (*sound design*) yang imersif dari <strong class="text-indigo-600">IdulStudio</strong>.
            </p>

            <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
                <a href="#gallery-portfolio" class="w-full sm:w-auto bg-indigo-600 hover:bg-indigo-500 text-white font-bold px-8 py-4 rounded-2xl shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/30 transition-all flex items-center justify-center gap-3 text-base">
                    <i class="fa-solid fa-play"></i>
                    Eksplor Galeri Karya
                </a>
                <a href="#hubungi-saya" class="w-full sm:w-auto bg-white hover:bg-slate-50 text-slate-800 font-bold px-8 py-4 rounded-2xl border border-slate-200 hover:border-slate-300 transition-all flex items-center justify-center gap-2 shadow-sm text-base">
                    Diskusi Kolaborasi (Gratis)
                </a>
            </div>

            <!-- Quick Metrics Section -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-20 pt-10 border-t border-slate-200/80">
                <div class="bg-white/70 backdrop-blur border border-white p-5 rounded-2xl shadow-sm">
                    <div class="flex justify-center mb-2 text-indigo-600 bg-indigo-50 w-10 h-10 rounded-xl items-center mx-auto">
                        <i class="fa-solid fa-fire text-lg"></i>
                    </div>
                    <div class="text-3xl font-black text-slate-900">5M+</div>
                    <div class="text-[10px] text-slate-500 mt-1 uppercase tracking-wider font-extrabold">Total Views Generated</div>
                </div>

                <div class="bg-white/70 backdrop-blur border border-white p-5 rounded-2xl shadow-sm">
                    <div class="flex justify-center mb-2 text-violet-600 bg-violet-50 w-10 h-10 rounded-xl items-center mx-auto">
                        <i class="fa-solid fa-arrow-trend-up text-lg"></i>
                    </div>
                    <div class="text-3xl font-black text-slate-900">85%</div>
                    <div class="text-[10px] text-slate-500 mt-1 uppercase tracking-wider font-extrabold">Avg. View Retention</div>
                </div>

                <div class="bg-white/70 backdrop-blur border border-white p-5 rounded-2xl shadow-sm">
                    <div class="flex justify-center mb-2 text-pink-600 bg-pink-50 w-10 h-10 rounded-xl items-center mx-auto">
                        <i class="fa-solid fa-users text-lg"></i>
                    </div>
                    <div class="text-3xl font-black text-slate-900">12+</div>
                    <div class="text-[10px] text-slate-500 mt-1 uppercase tracking-wider font-extrabold">Happy Brands & Creators</div>
                </div>

                <div class="bg-white/70 backdrop-blur border border-white p-5 rounded-2xl shadow-sm">
                    <div class="flex justify-center mb-2 text-blue-600 bg-blue-50 w-10 h-10 rounded-xl items-center mx-auto">
                        <i class="fa-solid fa-video text-lg"></i>
                    </div>
                    <div class="text-3xl font-black text-slate-900">200+</div>
                    <div class="text-[10px] text-slate-500 mt-1 uppercase tracking-wider font-extrabold">Videos Edited</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Admin Panel Dashboard Section -->
    <section id="admin-panel" class="py-12 px-6 bg-slate-100 border-y border-slate-200/80 relative scroll-mt-20 hidden">
        <div class="max-w-6xl mx-auto">
            <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 mb-8">
                <div>
                    <div class="flex items-center gap-2 text-indigo-700 bg-indigo-50 border border-indigo-100 rounded-lg px-2.5 py-1 text-xs font-bold w-fit mb-2">
                        <i class="fa-solid fa-gear"></i>
                        IdulStudio Control Hub
                    </div>
                    <h2 class="text-2xl font-black text-slate-900">Panel Manajemen Konten</h2>
                    <p class="text-slate-600 text-sm mt-1">
                        Atur seluruh data portfolio video dan akun media sosial kelolaan. Data tersimpan di web-browser Anda.
                    </p>
                </div>

                <!-- Sub-tabs in Admin mode -->
                <div class="flex flex-wrap gap-2 bg-white p-1.5 rounded-2xl border border-slate-200 shadow-sm w-full lg:w-auto justify-start">
                    <button onclick="setAdminTab('portfolio')" id="tab-btn-portfolio" class="px-4 py-2 rounded-xl text-xs font-bold transition-all bg-indigo-600 text-white shadow-sm">
                        Kelola Portofolio Video
                    </button>
                    <button onclick="setAdminTab('accounts')" id="tab-btn-accounts" class="px-4 py-2 rounded-xl text-xs font-bold transition-all text-slate-600 hover:text-slate-950 hover:bg-slate-50">
                        Kelola Brand & Mantan Klien
                    </button>
                    <button onclick="setAdminTab('data')" id="tab-btn-data" class="px-4 py-2 rounded-xl text-xs font-bold transition-all text-slate-600 hover:text-slate-950 hover:bg-slate-50">
                        Hosting & Cadangkan Data
                    </button>
                </div>
            </div>

            <!-- TAB 1: Portfolio Video Form -->
            <div id="admin-tab-portfolio" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
                <form id="portfolio-form" onsubmit="handleSavePortfolio(event)" class="lg:col-span-5 bg-white p-6 rounded-3xl border border-slate-200 shadow-sm space-y-4">
                    <h3 id="portfolio-form-title" class="text-sm font-bold uppercase tracking-wider text-indigo-600 flex items-center gap-2">
                        <i class="fa-solid fa-plus"></i> Tambah Video Baru
                    </h3>

                    <input type="hidden" id="edit-portfolio-id" value="">

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Judul Video *</label>
                        <input type="text" id="p-title" required placeholder="Contoh: Streetwear Transitions Reel" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Klien *</label>
                            <input type="text" id="p-client" required placeholder="Contoh: UrbanVibe Co." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Platform Video</label>
                            <select id="p-platform" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                                <option value="youtube">YouTube</option>
                                <option value="tiktok">TikTok</option>
                                <option value="instagram">Instagram</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Kategori / Style</label>
                            <input type="text" id="p-category" placeholder="Contoh: Fashion Vlog" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Video ID / Link *</label>
                            <input type="text" id="p-embedId" required placeholder="Youtube ID / TikTok Link" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Jumlah Views</label>
                            <input type="text" id="p-views" placeholder="Contoh: 150K+" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-slate-700 mb-1">Rasio Retensi %</label>
                            <input type="text" id="p-retention" placeholder="Contoh: 82%" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        </div>
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Link Gambar Thumbnail</label>
                        <input type="text" id="p-thumbnail" placeholder="https://images.unsplash.com/..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>

                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Deskripsi Teknik & Pacing</label>
                        <textarea id="p-description" rows="3" placeholder="Contoh: Transisi cepat, sinkronisasi audio, grading warna hangat..." class="w-full bg-slate-50 border border-slate-200 rounded-xl p-3 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors"></textarea>
                    </div>

                    <div class="flex gap-2 pt-2">
                        <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-4 rounded-xl text-sm transition shadow-md shadow-indigo-500/10">
                            Tambahkan ke Galeri
                        </button>
                        <button type="button" onclick="resetPortfolioForm()" id="btn-cancel-p-edit" class="bg-slate-200 hover:bg-slate-300 text-slate-800 font-bold py-3 px-4 rounded-xl text-sm border border-slate-300 hidden">
                            Batal
                        </button>
                    </div>
                </form>

                <div class="lg:col-span-7 bg-white p-6 rounded-3xl border border-slate-200 shadow-sm">
                  <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 mb-4">
                    Karya di Galeri Saat Ini (<span id="admin-portfolio-count">0</span>)
                  </h3>

                  <div id="admin-portfolio-list" class="space-y-3 max-h-[520px] overflow-y-auto pr-2">
                      <!-- Dynamically Filled -->
                  </div>
                </div>
            </div>

            <!-- TAB 2: Managed Accounts Form -->
            <div id="admin-tab-accounts" class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start hidden">
                <form id="accounts-form" onsubmit="handleSaveAccount(event)" class="lg:col-span-5 bg-white p-6 rounded-3xl border border-slate-200 shadow-sm space-y-4">
                  <h3 id="account-form-title" class="text-sm font-bold uppercase tracking-wider text-indigo-600 flex items-center gap-2">
                    <i class="fa-solid fa-plus"></i> Tambah Brand Baru
                  </h3>

                  <input type="hidden" id="edit-account-id" value="">

                  <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Nama Akun / Brand *</label>
                    <input type="text" id="a-name" required placeholder="Contoh: @selera_nusantara" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                  </div>

                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-bold text-slate-700 mb-1">Platform Utama</label>
                      <select id="a-platform" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                        <option value="instagram">Instagram</option>
                        <option value="tiktok">TikTok</option>
                        <option value="youtube">YouTube</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-xs font-bold text-slate-700 mb-1">Niche / Industri</label>
                      <input type="text" id="a-niche" placeholder="Contoh: F&B, Gadget, Edukasi" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>
                  </div>

                  <div class="grid grid-cols-3 gap-2">
                    <div>
                      <label class="block text-xs font-bold text-slate-700 mb-1">Followers *</label>
                      <input type="text" id="a-followers" required placeholder="Contoh: 120K" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-2.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>
                    <div>
                      <label class="block text-xs font-bold text-slate-700 mb-1">Growth MoM</label>
                      <input type="text" id="a-growth" placeholder="Contoh: +15%" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-2.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>
                    <div>
                      <label class="block text-xs font-bold text-slate-700 mb-1">Avg Views</label>
                      <input type="text" id="a-avgViews" placeholder="Contoh: 50K" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-2.5 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                    </div>
                  </div>

                  <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Link Logo Brand</label>
                    <input type="text" id="a-logo" placeholder="https://images.unsplash.com/..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                  </div>

                  <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Peran Anda di Akun ini</label>
                    <input type="text" id="a-role" placeholder="Contoh: Full-Time Video Editor" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-900 focus:outline-none focus:border-indigo-500 focus:bg-white transition-colors">
                  </div>

                  <div class="flex gap-2 pt-2">
                    <button type="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-3 px-4 rounded-xl text-sm transition">
                      Tambahkan Akun
                    </button>
                    <button type="button" onclick="resetAccountForm()" id="btn-cancel-a-edit" class="bg-slate-200 hover:bg-slate-300 text-slate-800 font-bold py-3 px-4 rounded-xl text-sm border border-slate-300 hidden">
                      Batal
                    </button>
                  </div>
                </form>

                <div class="lg:col-span-7 bg-white p-6 rounded-3xl border border-slate-200 shadow-sm">
                  <h3 class="text-sm font-bold uppercase tracking-wider text-slate-900 mb-4">
                    Mantan Klien / Sosmed Kelolaan Saat Ini (<span id="admin-accounts-count">0</span>)
                  </h3>

                  <div id="admin-accounts-list" class="space-y-3 max-h-[520px] overflow-y-auto pr-2">
                      <!-- Dynamically Filled -->
                  </div>
                </div>
            </div>

            <!-- TAB 3: Data Migration Guide -->
            <div id="admin-tab-data" class="bg-white p-6 rounded-3xl border border-slate-200 shadow-sm space-y-6 hidden">
                <div>
                  <h3 class="text-lg font-black text-slate-900">Petunjuk Hosting Permanen di Vercel</h3>
                  <p class="text-slate-600 text-sm mt-1 leading-relaxed">
                    Karena website statis yang Anda rilis di Vercel menggunakan penyimpanan lokal (*LocalStorage*) browser, perubahan yang Anda buat melalui formulir admin hanya akan tersimpan di perangkat Anda. Agar isi portofolio Anda **permanen dan dapat dilihat oleh semua orang**, lakukan langkah mudah berikut:
                  </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div class="bg-slate-50 p-5 rounded-2xl border border-slate-200 flex flex-col justify-between">
                    <div>
                      <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600 mb-4">
                        <i class="fa-solid fa-download text-lg"></i>
                      </div>
                      <h4 class="font-bold text-slate-900 mb-1 text-sm">Unduh File Cadangan</h4>
                      <p class="text-xs text-slate-500 leading-relaxed">
                        Unduh semua data portofolio dan brand klien terbaru Anda sebagai file `.json`.
                      </p>
                    </div>
                    <button onclick="exportData()" type="button" class="mt-6 w-full bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2.5 rounded-xl text-xs transition">
                      Unduh Sekarang
