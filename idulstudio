            const platform = document.getElementById('a-platform').value;
            const niche = document.getElementById('a-niche').value || 'General';
            const followers = document.getElementById('a-followers').value;
            const growth = document.getElementById('a-growth').value || 'Steady';
            const avgViews = document.getElementById('a-avgViews').value || 'N/A';
            const logoInput = document.getElementById('a-logo').value;
            const role = document.getElementById('a-role').value || 'Editor / Planner';

            const defaultLogos = {
              instagram: 'https://images.unsplash.com/photo-1611224885990-ab7363d1f2a9?auto=format&fit=crop&w=150&q=80',
              tiktok: 'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=150&q=80',
              youtube: 'https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?auto=format&fit=crop&w=150&q=80'
            };

            const logo = logoInput.trim() !== '' 
              ? logoInput 
              : (defaultLogos[platform] || 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=150&q=80');

            if (editId) {
                managedAccounts = managedAccounts.map(acc => acc.id === editId ? {
                    id: editId, name, platform, niche, followers, growth, avgViews, logo, role
                } : acc);
                showAlert('Data brand klien berhasil diperbarui!');
            } else {
                const newAcc = {
                    id: 'acc_' + Date.now(),
                    name, platform, niche, followers, growth, avgViews, logo, role
                };
                managedAccounts.push(newAcc);
                showAlert('Akun kelolaan baru berhasil ditambahkan!');
            }

            syncAccounts();
            resetAccountForm();
            renderAll();
        }

        function resetAccountForm() {
            document.getElementById('edit-account-id').value = '';
            document.getElementById('a-name').value = '';
            document.getElementById('a-platform').value = 'instagram';
            document.getElementById('a-niche').value = '';
            document.getElementById('a-followers').value = '';
            document.getElementById('a-growth').value = '';
            document.getElementById('a-avgViews').value = '';
            document.getElementById('a-logo').value = '';
            document.getElementById('a-role').value = '';

            document.getElementById('account-form-title').innerHTML = `<i class="fa-solid fa-plus"></i> Tambah Brand Baru`;
            document.getElementById('btn-cancel-a-edit').classList.add('hidden');
        }

        function editAccountClick(id) {
            const acc = managedAccounts.find(a => a.id === id);
            if (!acc) return;

            document.getElementById('edit-account-id').value = acc.id;
            document.getElementById('a-name').value = acc.name;
            document.getElementById('a-platform').value = acc.platform;
            document.getElementById('a-niche').value = acc.niche;
            document.getElementById('a-followers').value = acc.followers;
            document.getElementById('a-growth').value = acc.growth;
            document.getElementById('a-avgViews').value = acc.avgViews;
            document.getElementById('a-logo').value = acc.logo;
            document.getElementById('a-role').value = acc.role;

            document.getElementById('account-form-title').innerHTML = `<i class="fa-solid fa-pen-to-square"></i> Edit Brand Klien`;
            document.getElementById('btn-cancel-a-edit').classList.remove('hidden');

            document.getElementById('admin-panel').scrollIntoView({ behavior: 'smooth' });
        }

        function deleteAccount(id) {
            managedAccounts = managedAccounts.filter(a => a.id !== id);
            syncAccounts();
            showAlert('Data brand kelolaan berhasil dihapus!');
            renderAll();
        }

        // Export Data JSON
        function exportData() {
            const fullData = {
                portfolio: portfolioItems,
                accounts: managedAccounts
            };
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(fullData, null, 2));
            const downloadAnchor = document.createElement('a');
            downloadAnchor.setAttribute("href", dataStr);
            downloadAnchor.setAttribute("download", "idulstudio_backup_v2.json");
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
            showAlert('Data JSON berhasil diekspor! Simpan file ini untuk cadangan.');
        }

        // Import Data JSON
        function handleImportJson(e) {
            const fileReader = new FileReader();
            if (e.target.files && e.target.files[0]) {
                fileReader.readAsText(e.target.files[0], "UTF-8");
                fileReader.onload = (event) => {
                    try {
                        const parsed = JSON.parse(event.target.result);
                        if (parsed.portfolio && Array.isArray(parsed.portfolio)) {
                            portfolioItems = parsed.portfolio;
                            syncPortfolio();
                        }
                        if (parsed.accounts && Array.isArray(parsed.accounts)) {
                            managedAccounts = parsed.accounts;
                            syncAccounts();
                        }
                        showAlert('Data sukses diimpor ke sistem lokal browser Anda!');
                        renderAll();
                    } catch (err) {
                        showAlert('Format file tidak sesuai atau rusak!', 'error');
                    }
                };
            }
        }

        // Copy Code Format to Clipboard
        function copyCodeForVercel() {
            const codeFormat = {
              DEFAULT_PORTFOLIO: portfolioItems,
              DEFAULT_ACCOUNTS: managedAccounts
            };
            const codeString = JSON.stringify(codeFormat, null, 2);
            
            // Safe copy to clipboard
            const el = document.createElement('textarea');
            el.value = codeString;
            document.body.appendChild(el);
            el.select();
            document.execCommand('copy');
            document.body.removeChild(el);

            showAlert('Kode JSON disalin! Tempel di baris DEFAULT_PORTFOLIO/ACCOUNTS.');
        }

        // Reset Data custom modal triggers
        function openResetModal() {
            document.getElementById('confirm-reset-modal').classList.remove('hidden');
            document.getElementById('confirm-reset-modal').classList.add('flex');
        }

        function closeResetModal() {
            document.getElementById('confirm-reset-modal').classList.add('hidden');
            document.getElementById('confirm-reset-modal').classList.remove('flex');
        }

        function handleResetToDefault() {
            portfolioItems = DEFAULT_PORTFOLIO;
            managedAccounts = DEFAULT_ACCOUNTS;
            syncPortfolio();
            syncAccounts();
            closeResetModal();
            showAlert('Kembali ke data bawaan IdulStudio!');
            renderAll();
        }

        // Contact briefing handler
        function handleSendBrief(e) {
            e.preventDefault();
            showAlert('Brief Anda berhasil dikirim! Tim IdulStudio akan segera menghubungi Anda.');
            e.target.reset();
        }

        // Open Modal Player Video
        function openVideoModal(id) {
            const item = portfolioItems.find(i => i.id === id);
            if (!item) return;

            document.getElementById('modal-platform-badge').innerText = `${item.platform} • ${item.category}`;
            document.getElementById('modal-video-title').innerText = item.title;
            document.getElementById('modal-video-desc').innerText = item.description;
            document.getElementById('modal-client-text').innerText = item.client;
            document.getElementById('modal-views-text').innerText = item.views;

            const retentionRow = document.getElementById('modal-retention-row');
            if (item.retention && item.retention !== 'N/A') {
                retentionRow.classList.remove('hidden');
                document.getElementById('modal-retention-text').innerText = item.retention;
            } else {
                retentionRow.classList.add('hidden');
            }

            const videoContainer = document.getElementById('modal-video-container');

            if (item.platform === 'youtube') {
                videoContainer.innerHTML = `
                    <iframe 
                      class="w-full h-full"
                      src="https://www.youtube.com/embed/${item.embedId}?autoplay=1&rel=0"
                      title="${item.title}"
                      frameborder="0"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    ></iframe>
                `;
            } else {
                // Portrait TikTok / Reels mock player
                const externalLink = item.embedId.includes('http') ? item.embedId : "https://tiktok.com";
                videoContainer.innerHTML = `
                    <div class="w-full h-full flex flex-col items-center justify-center bg-slate-900 text-center p-6 relative">
                      <div class="w-[150px] sm:w-[180px] aspect-[9/16] bg-slate-950 rounded-3xl border-4 border-slate-700 overflow-hidden shadow-2xl relative flex flex-col justify-between">
                        <img src="${item.thumbnail}" alt="Vertical Thumbnail" class="absolute inset-0 w-full h-full object-cover filter brightness-75">
                        
                        <div class="relative z-10 p-3 flex justify-between items-center text-white/80">
                          <span class="text-[8px] font-bold">Mengikuti</span>
                          <span class="text-[8px] font-bold border-b-2 border-white pb-0.5">Untuk Anda</span>
                        </div>

                        <div class="relative z-10 flex items-center justify-center">
                          <div class="w-10 h-10 bg-indigo-600/90 rounded-full flex items-center justify-center text-white">
                            <i class="fa-solid fa-play ml-0.5"></i>
                          </div>
                        </div>

                        <div class="relative z-10 p-3 text-left text-[9px] text-white bg-gradient-to-t from-black/80 via-black/30 to-transparent">
                          <p class="font-bold">${item.client}</p>
                          <p class="line-clamp-2 text-slate-200 mt-1">${item.title}</p>
                        </div>
                      </div>

                      <div class="mt-4 z-10 text-center">
                        <p class="text-xs text-slate-300 max-w-sm">
                          Mendeteksi format video vertikal. Klik tautan di bawah untuk melihat karya asli:
                        </p>
                        <a href="${externalLink}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs text-indigo-400 hover:text-indigo-300 font-bold mt-2">
                          Buka Link Video Asli <i class="fa-solid fa-arrow-up-right-from-square"></i>
                        </a>
                      </div>
                    </div>
                `;
            }

            const modal = document.getElementById('video-modal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        // Close Modal Video
        function closeVideoModal() {
            const modal = document.getElementById('video-modal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            
            // Stop playing when closing (Clearing iframe elements)
            document.getElementById('modal-video-container').innerHTML = '';
        }
    </script>
</body>
</html>
