            document.getElementById('p-platform').value = 'youtube';
            document.getElementById('p-category').value = '';
            document.getElementById('p-embedId').value = '';
            document.getElementById('p-views').value = '';
            document.getElementById('p-retention').value = '';
            document.getElementById('p-thumbnail').value = '';
            document.getElementById('p-description').value = '';

            document.getElementById('portfolio-form-title').innerHTML = `<i class="fa-solid fa-plus"></i> Tambah Video Baru`;
            document.getElementById('btn-cancel-p-edit').classList.add('hidden');
        }

        function editPortfolioClick(id) {
            const item = portfolioItems.find(i => i.id === id);
            if (!item) return;

            document.getElementById('edit-portfolio-id').value = item.id;
            document.getElementById('p-title').value = item.title;
            document.getElementById('p-client').value = item.client;
            document.getElementById('p-platform').value = item.platform;
            document.getElementById('p-category').value = item.category;
            document.getElementById('p-embedId').value = item.embedId;
            document.getElementById('p-views').value = item.views;
            document.getElementById('p-retention').value = item.retention;
            document.getElementById('p-thumbnail').value = item.thumbnail;
            document.getElementById('p-description').value = item.description;

            document.getElementById('portfolio-form-title').innerHTML = `<i class="fa-solid fa-pen-to-square"></i> Edit Video Portofolio`;
            document.getElementById('btn-cancel-p-edit').classList.remove('hidden');

            document.getElementById('admin-panel').scrollIntoView({ behavior: 'smooth' });
        }

        function deletePortfolio(id) {
            portfolioItems = portfolioItems.filter(i => i.id !== id);
