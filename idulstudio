        // Notification Alerts
        function showAlert(msg, type = 'success') {
            const toast = document.getElementById('alert-toast');
            const toastIcon = document.getElementById('alert-icon');
            const toastMsg = document.getElementById('alert-msg');

            toastMsg.innerText = msg;
            if (type === 'error') {
                toast.className = "fixed top-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-xl backdrop-blur-md border border-red-200 bg-red-50 text-red-800 transition-all duration-300 transform translate-y-0 opacity-100";
                toastIcon.className = "fa-solid fa-triangle-exclamation text-red-500 text-lg";
            } else {
                toast.className = "fixed top-5 right-5 z-50 flex items-center gap-3 px-5 py-4 rounded-xl shadow-xl backdrop-blur-md border border-emerald-200 bg-emerald-50 text-emerald-800 transition-all duration-300 transform translate-y-0 opacity-100";
                toastIcon.className = "fa-solid fa-circle-check text-emerald-500 text-lg";
            }

            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-[-150%]');
                toast.classList.remove('opacity-100', 'translate-y-0');
            }, 3500);
        }

        // Save Portfolio Item (Add/Edit)
        function handleSavePortfolio(e) {
            e.preventDefault();
            const editId = document.getElementById('edit-portfolio-id').value;
            const title = document.getElementById('p-title').value;
            const client = document.getElementById('p-client').value;
            const platform = document.getElementById('p-platform').value;
            const category = document.getElementById('p-category').value || 'General Video';
            const embedId = document.getElementById('p-embedId').value;
            const views = document.getElementById('p-views').value || 'N/A';
            const retention = document.getElementById('p-retention').value || 'N/A';
            const thumbnailInput = document.getElementById('p-thumbnail').value;
            const description = document.getElementById('p-description').value;

            const defaultThumbs = {
                youtube: 'https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7?auto=format&fit=crop&w=800&q=80',
                instagram: 'https://images.unsplash.com/photo-1611224885990-ab7363d1f2a9?auto=format&fit=crop&w=800&q=80',
                tiktok: 'https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=800&q=80'
            };

            const thumbnail = thumbnailInput.trim() !== '' 
              ? thumbnailInput 
              : (defaultThumbs[platform] || 'https://images.unsplash.com/photo-1536240478700-b869070f9279?auto=format&fit=crop&w=800&q=80');

            if (editId) {
                // Update
                portfolioItems = portfolioItems.map(item => item.id === editId ? {
                    id: editId, title, client, platform, category, thumbnail, embedId, views, retention, description
                } : item);
                showAlert('Portofolio berhasil diperbarui!');
            } else {
                // Add new
                const newItem = {
                    id: 'port_' + Date.now(),
                    title, client, platform, category, thumbnail, embedId, views, retention, description
                };
                portfolioItems.unshift(newItem);
                showAlert('Karya portofolio baru ditambahkan!');
            }

            syncPortfolio();
            resetPortfolioForm();
            renderAll();
        }

        function resetPortfolioForm() {
            document.getElementById('edit-portfolio-id').value = '';
            document.getElementById('p-title').value = '';
